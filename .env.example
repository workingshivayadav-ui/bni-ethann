# Express backend URL (used by SSR and CSV export)
API_URL=http://localhost:4000

# Optional: set for client-side direct API calls (leave empty to use Vite proxy in dev)
# VITE_API_URL=http://localhost:4000

# MongoDB — members saved to the `bniethan` database, `members` collection
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/bniethan

# Cloudinary (set in backend/config/.env locally, Railway dashboard for production)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
