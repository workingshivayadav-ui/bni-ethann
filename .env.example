# Express backend URL (used by SSR and CSV export)
API_URL=http://localhost:4000

# Optional: set for client-side direct API calls (leave empty to use Vite proxy in dev)
# VITE_API_URL=http://localhost:4000

# MongoDB — members saved to the `prescripto` database, `members` collection
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/prescripto
